# Spring Boot bootRun 用環境変数
# cp .env.bootRun.example .env.bootRun して実際の値を設定する
# 起動: ./gradlew sandbox-api:bootRun  ※ build.gradle が自動読み込みするため source 不要

SPRING_PROFILES_ACTIVE=local

APP_NAME=sandbox

# ストレージ
BUCKET_NAME=../local/storage

# MySQL（docker compose で起動した場合のデフォルトポート: 43306）
DB_HOST=localhost
DB_PORT=43306
DB_SCHEMA=sandbox1
DB_USER=sandbox_api
DB_PASSWORD=your_db_password

# Redis（docker compose で起動した場合のデフォルトポート: 46379）
REDIS_HOST=localhost
REDIS_PORT=46379

# AWS Cognito JWT 検証
JWT_ISSUER=https://cognito-idp.ap-northeast-1.amazonaws.com/ap-northeast-1_YourUserPoolId
JWT_AUDIENCE1=your_cognito_app_client_id_1
JWT_AUDIENCE2=your_cognito_app_client_id_2
JWT_AUDIENCE3=your_cognito_app_client_id_3

# CORS 許可オリジン
JWT_ORIGIN1=http://localhost
JWT_ORIGIN2=http://localhost:3000
