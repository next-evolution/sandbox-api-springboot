        <BeanShellSampler guiclass="BeanShellSamplerGui" testclass="BeanShellSampler" testname="BeanShell_adminEmail を Base64 エンコード" enabled="true">
          <stringProp name="BeanShellSampler.query">
import java.util.Base64;
String email = vars.get(&quot;adminEmail&quot;);
String encoded = Base64.getEncoder().encodeToString(email.getBytes(&quot;UTF-8&quot;));
vars.put(&quot;adminEmailEncoded&quot;, encoded);

String countStr = vars.get(&quot;__adminIter&quot;);
int count = (countStr == null || countStr.isEmpty()) ? 0 : Integer.parseInt(countStr);
count++;
vars.put(&quot;__adminIter&quot;, String.valueOf(count));
vars.put(&quot;isFirstAdminLoop&quot;, count == 1 ? &quot;true&quot; : &quot;false&quot;);
          </stringProp>
        </BeanShellSampler>
