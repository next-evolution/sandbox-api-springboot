# docs: yaml/md のみ管理対象、それ以外は除外
docs/*
!docs/*.yaml
!docs/*.md
!docs/index.html

# env
.env.compose
.env.bootRun

# local: Docker ボリュームマウント（backup shell のみ管理対象）
local/*
!local/work/backup_sandbox.sh

# tools/jmeter: 生成物・実行ログは除外
tools/jmeter/response/
tools/jmeter/result/
tools/jmeter/tmp/
tools/jmeter/jmeter.log

# tools/jmeter/data: セキュリティ情報を含む CSV は除外（*.csv.example のみ管理対象）
tools/jmeter/data/admin_user.csv
tools/jmeter/data/settings.csv
tools/jmeter/data/user.csv

/.idea/**
/.run/**

.gradle
**/build/
**/bin/
!**/src/**/build/

.env

# Ignore Gradle GUI config
gradle-app.setting

# Avoid ignoring Gradle wrapper jar file (.jar files are usually ignored)
!gradle-wrapper.jar

# Avoid ignore Gradle wrappper properties
!gradle-wrapper.properties

# Cache of project
.gradletasknamecache

# Eclipse Gradle plugin generated files
# Eclipse Core
.project
# JDT-specific (Eclipse Java Development Tools)
.classpath

# Editor/IDE
.idea/
.vscode/
.DS_Store
